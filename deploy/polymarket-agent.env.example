POLYMARKET_OUTPUT_DIR=/data/polymarket-agent/output
POLYMARKET_PUBLISH_DIR=/data/polymarket-agent/publish
POLYMARKET_STATE_DIR=/data/polymarket-agent/state
POLYMARKET_TIMEFRAMES=5m,15m,1h,4h
POLYMARKET_POLL_INTERVAL_SECONDS=30
POLYMARKET_GRACE_PERIOD_SECONDS=120
POLYMARKET_FLUSH_INTERVAL_SECONDS=5
POLYMARKET_MATERIALIZE_INTERVAL_SECONDS=60
POLYMARKET_MATERIALIZE_STABLE_SECONDS=300
POLYMARKET_MATERIALIZE_LINK_MODE=hardlink
POLYMARKET_API_BIND=127.0.0.1
POLYMARKET_API_PORT=8080
POLYMARKET_API_DEFAULT_LIMIT=200
POLYMARKET_API_MAX_LIMIT=5000
POLYMARKET_API_AUTH_MODE=bearer
POLYMARKET_API_BEARER_TOKEN=
POLYMARKET_API_SERVER_NAME=_
POLYMARKET_TLS_CERT_PATH=/etc/nginx/ssl/polymarket-data-api.crt
POLYMARKET_TLS_KEY_PATH=/etc/nginx/ssl/polymarket-data-api.key
POLYMARKET_TLS_CERT_DAYS=365
POLYMARKET_TLS_CN=
POLYMARKET_TLS_SAN=
POLYMARKET_LOG_LEVEL=INFO

TENCENT_COS_BUCKET=polymarket-ai-agent-1328550492
TENCENT_COS_REGION=ap-tokyo
TENCENT_COS_PREFIX=
TENCENT_COS_SYNC_INTERVAL_SECONDS=60
TENCENT_COS_STABLE_SECONDS=60
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
